<% layout("layouts/boilerplate") %>

<!-- Filters button (only visible on mobile) -->
<button class="btn btn-outline-secondary d-md-none mb-2"
        data-bs-toggle="collapse"
        data-bs-target="#filterCollapse">
    <i class="fa-solid fa-sliders"></i> Filters
</button>

<!-- Collapsible wrapper -->
<div id="filterCollapse" class="collapse d-md-block">
    <div class="filters-wrapper">
        <div id="filters">
            <div class="filter">
                <div><i class="fa-solid fa-fire"></i></div>
                <p>Trending</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-bed"></i></div>
                <p>Rooms</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-mountain-city"></i></div>
                <p>Iconic Cities</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-mountain"></i></div>
                <p>Mountain</p>
            </div>
            <div class="filter">
                <div><i class="fa-brands fa-fort-awesome"></i></div>
                <p>Castles</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-person-swimming"></i></div>
                <p>Amazing Pools</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-campground"></i></div>
                <p>Camping</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-cow"></i></div>
                <p>Farms</p>
            </div>
            <div class="filter">
                <div><i class="fa-regular fa-snowflake"></i></div>
                <p>Arctic</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-landmark-dome"></i></div>
                <p>Domes</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-ship"></i></div>
                <p>Boats</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-umbrella-beach"></i></div>
                <p>Beachfront</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-gem"></i></div>
                <p>Luxe</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-tree"></i></div>
                <p>Treehouses</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-dungeon"></i></div>
                <p>Caves</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-water"></i></div>
                <p>Surfing</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-person-skiing"></i></div>
                <p>Skiing</p>
            </div>
        </div>
    </div>
</div>

<%# ── Search context banner ─────────────────────────────── %>
<% if (searchQuery) { %>
  <div class="d-flex align-items-center gap-2 mt-3 mb-1">
    <h5 class="mb-0">Results for &ldquo;<span class="text-danger"><%= searchQuery %></span>&rdquo;</h5>
    <a href="/listings" class="btn btn-sm btn-outline-secondary ms-2">Clear</a>
  </div>
<% } %>

<%# ── Compass AI context banner ─────────────────────────── %>
<% if (compassQuery) { %>
  <div class="d-flex align-items-center gap-2 mt-3 mb-1">
    <h5 class="mb-0">Compass found stays for &ldquo;<span class="text-danger"><%= compassQuery %></span>&rdquo;</h5>
    <a href="/listings" class="btn btn-sm btn-outline-secondary ms-2">Clear filters</a>
  </div>
<% } %>

<% if (alllistings.length === 0) { %>
  <%# ── No-results empty state ── %>
  <div class="text-center py-5">
    <i class="fa-solid fa-magnifying-glass fa-3x text-muted mb-3"></i>
    <h4 class="mt-3 text-muted">
      No listings found for &ldquo;<span class="text-danger"><%= searchQuery || compassQuery %></span>&rdquo;
    </h4>
    <p class="text-muted">Try a different search query or rephrase your request to Compass.</p>
    <a href="/listings" class="btn btn-danger mt-2">Browse all listings</a>
  </div>
<% } else { %>
  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for(let listings of alllistings){ %>
    <a href="/listings/<%= listings._id %>" class="listing-link">
    <div class="card col listing-card">
        <div class="card-img-container">
            <img src="<%= listings.image.url %>" class="card-img-top" alt="listing image">
            <div class="card-img-overlay"></div>
        </div>
        <div class="card-body">
            <p class="card-text">
                <b><%= listings.title %></b><br>
                <span class="price-container">
                    &#8377;<%= listings.price.toLocaleString("en-IN") %> <span class="price-label">/ night</span>
                </span>
                <i class="tax-info">&nbsp; &nbsp; +18% GST</i>
            </p>
        </div>
    </div>
    </a>
    <% } %>
  </div>
<% } %>
<!-- Compass AI Travel Assistant Widget (Index Page Only) -->
<link href="/css/compass.css" rel="stylesheet">
<%- include("../includes/compass.ejs") %>
<script src="/js/compass.js"></script>
