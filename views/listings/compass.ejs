<% layout("layouts/boilerplate") %>

<script type="application/json" id="compass-listings-data">
<%- JSON.stringify(
  allListings.map(function(l) {
    return {
      id:       l._id.toString(),
      title:    l.title    || "Untitled Listing",
      location: l.location || "",
      country:  l.country  || "",
      price:    l.price    || 0,
      image:    (l.image && l.image.url)
                  ? l.image.url
                  : "https://images.unsplash.com/photo-1625505826533-5c80aca7d157?w=600&q=80",
      href:     "/listings/" + l._id.toString()
    };
  })
) %>
</script>

<section id="compass-listings-section" class="compass-page-section">

  <div class="compass-page-hero">
    <div class="compass-page-hero__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="9"/>
        <polygon points="12,3 14.5,12 12,10 9.5,12"   fill="#FF385C" stroke="none"/>
        <polygon points="12,21 9.5,12 12,14 14.5,12"  fill="rgba(255,56,92,0.4)" stroke="none"/>
        <circle  cx="12" cy="12" r="1.5"              fill="#FF385C" stroke="none"/>
      </svg>
    </div>

    <div>
      <h1 class="compass-page-hero__title">Discover your perfect stay</h1>
      <p class="compass-page-hero__subtitle">
        Ask Compass anything — a city, a vibe, a budget —
        and watch your real listings filter instantly.
      </p>
    </div>

    <div class="compass-chips" aria-label="Suggested searches">
      <button class="compass-chip" data-query="stays in Kolhapur">📍 Kolhapur</button>
      <button class="compass-chip" data-query="beach stays">🏖️ Beach</button>
      <button class="compass-chip" data-query="mountain retreats">🏔️ Mountain</button>
      <button class="compass-chip" data-query="budget stays under ₹3000">💰 Budget picks</button>
      <button class="compass-chip" data-query="luxury stays">✨ Luxury</button>
      <button class="compass-chip" data-query="romantic getaway for couples">❤️ Romantic</button>
    </div>
  </div>

  <div class="compass-listings-header">
    <h2 class="compass-listings-title" id="compass-result-count">All Stays</h2>
    <button id="compass-clear-filters" aria-label="Clear active filters">
      Clear filters ×
    </button>
  </div>

  <div id="compass-cards-grid" class="compass-cards-grid"
       aria-live="polite" aria-label="Listing results">
    <div class="compass-skeleton"></div>
    <div class="compass-skeleton"></div>
    <div class="compass-skeleton"></div>
    <div class="compass-skeleton"></div>
  </div>

</section>


<style>
  .compass-page-section {
    padding: 32px 0 64px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  .compass-page-hero {
    text-align: center;
    margin-bottom: 36px;
  }
  .compass-page-hero__icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 16px;
    background: #FFF0F3;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .compass-page-hero__icon svg { width: 36px; height: 36px; }

  .compass-page-hero__title {
    font-size: clamp(22px, 4vw, 32px);
    font-weight: 600;
    color: #222222;
    margin: 0 0 10px;
  }
  .compass-page-hero__subtitle {
    font-size: 15px;
    color: #717171;
    max-width: 520px;
    margin: 0 auto 24px;
    line-height: 1.6;
  }

  .compass-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }
  .compass-chip {
    font-family: inherit;
    font-size: 13px;
    font-weight: 500;
    color: #222222;
    background: #FFFFFF;
    border: 1px solid #DDDDDD;
    border-radius: 20px;
    padding: 8px 16px;
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
  }
  .compass-chip:hover {
    border-color: #222222;
    background: #222222;
    color: #FFFFFF;
  }

  .compass-skeleton {
    border-radius: 12px;
    height: 280px;
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: compass-skeleton-shimmer 1.4s infinite;
  }
  @keyframes compass-skeleton-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
</style>

<!-- Chip → Compass panel integration -->
<script>
  document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll(".compass-chip").forEach(function (chip) {
      chip.addEventListener("click", function () {
        var query   = chip.getAttribute("data-query");
        var input   = document.getElementById("compass-input");
        var trigger = document.getElementById("compass-trigger");
        var panel   = document.getElementById("compass-panel");
        if (input && trigger && panel) {
          if (!panel.classList.contains("is-open")) trigger.click();
          input.value = query;
          input.focus();
        }
      });
    });
  });
</script>
